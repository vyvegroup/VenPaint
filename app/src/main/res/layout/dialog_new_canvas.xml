<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/venpaint_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Canvas Name"
        android:textColor="@color/venpaint_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Untitled"
        android:textColor="@color/venpaint_text_primary"
        android:textColorHint="@color/venpaint_text_hint"
        android:backgroundTint="@color/venpaint_accent"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dimensions (pixels)"
        android:textColor="@color/venpaint_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/editWidth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Width"
            android:textColor="@color/venpaint_text_primary"
            android:textColorHint="@color/venpaint_text_hint"
            android:backgroundTint="@color/venpaint_accent"
            android:inputType="number"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="×"
            android:textColor="@color/venpaint_text_hint"
            android:textSize="18sp"
            android:layout_gravity="center_vertical" />

        <EditText
            android:id="@+id/editHeight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Height"
            android:textColor="@color/venpaint_text_primary"
            android:textColorHint="@color/venpaint_text_hint"
            android:backgroundTint="@color/venpaint_accent"
            android:inputType="number"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Presets"
        android:textColor="@color/venpaint_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <GridLayout
        android:id="@+id/presetsGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:useDefaultMargins="true" />

</LinearLayout>
