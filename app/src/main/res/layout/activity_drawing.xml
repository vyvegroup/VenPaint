<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/venpaint_background">

    <!-- Top toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:titleTextColor="@color/venpaint_text_primary" />

    <!-- Drawing Canvas -->
    <com.venpaint.app.ui.DrawingCanvas
        android:id="@+id/drawingCanvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/brushSettingsPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Layer Panel (overlay) -->
    <FrameLayout
        android:id="@+id/layerPanelContainer"
        android:layout_width="300dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/venpaint_panel_bg"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/brushSettingsPanel"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Brush Settings Bar -->
    <com.venpaint.app.ui.BrushSettingsPanel
        android:id="@+id/brushSettingsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="4dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Toolbar -->
    <com.venpaint.app.ui.ToolBar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
