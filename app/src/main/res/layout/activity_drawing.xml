<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/venpaint_toolbar_bg">

    <!-- ==================== TOP TOOLBAR ==================== -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="4dp"
        app:titleTextColor="@color/venpaint_text_primary"
        app:titleTextAppearance="@style/TextAppearance.VenPaint.ToolbarTitle"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/venpaint_accent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== LEFT TOOL PALETTE (Vertical) ==================== -->
    <com.venpaint.app.ui.ToolBar
        android:id="@+id/toolbar"
        android:layout_width="48dp"
        android:layout_height="0dp"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ==================== DRAWING CANVAS (Center) ==================== -->
    <com.venpaint.app.ui.DrawingCanvas
        android:id="@+id/drawingCanvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toEndOf="@id/toolbar"
        app:layout_constraintEnd_toStartOf="@id/brushSettingsPanel" />

    <!-- ==================== RIGHT BRUSH SETTINGS PANEL ==================== -->
    <com.venpaint.app.ui.BrushSettingsPanel
        android:id="@+id/brushSettingsPanel"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="4dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== LAYER PANEL (Overlay on canvas) ==================== -->
    <FrameLayout
        android:id="@+id/layerPanelContainer"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/venpaint_panel_bg"
        android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toEndOf="@id/toolbar" />

    <!-- ==================== BOTTOM BAR (Layer strip + Color picker strip) ==================== -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/venpaint_toolbar_bg"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Color preview circle -->
        <ImageView
            android:id="@+id/bottomColorPreview"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_share"
            android:scaleType="centerCrop"
            android:contentDescription="Current color"
            android:padding="2dp" />

        <!-- Spacer -->
        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Recent colors strip -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recentColorsStrip"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@android:color/transparent" />

        <!-- Color picker button -->
        <ImageButton
            android:id="@+id/bottomColorPickerBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_tool_color"
            android:contentDescription="Color picker"
            android:padding="4dp"
            app:tint="@color/venpaint_accent" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
